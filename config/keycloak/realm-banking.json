{
  "realm": "banking",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "roles": {
    "realm": [
      {
        "name": "transfer_read",
        "description": "Read transfer state"
      },
      {
        "name": "transfer_write",
        "description": "Create and cancel transfers"
      }
    ]
  },
  "clientScopes": [
    {
      "name": "customer-id",
      "description": "Adds the banking customer id to access tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "customerId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "customerId",
            "claim.name": "customerId",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "transfer-service-audience",
      "description": "Adds transfer-service to token audiences",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-transfer-service",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "transfer-service",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "price-advisor-ui",
      "name": "Price Advisor UI",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "bearerOnly": false,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:7000/*",
        "http://localhost:8079/*"
      ],
      "webOrigins": [
        "http://localhost:7000",
        "http://localhost:8079"
      ],
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "customer-id",
        "transfer-service-audience"
      ],
      "protocolMappers": [
        {
          "name": "customerId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "customerId",
            "claim.name": "customerId",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "aud-transfer-service",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "transfer-service",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "aud-banking-gateway",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "banking-gateway",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "banking-gateway",
      "name": "Banking Gateway",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "gateway-secret",
      "bearerOnly": false,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "http://localhost:8079/*"
      ],
      "webOrigins": [
        "http://localhost:8079"
      ],
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "attributes": {
        "standard.token.exchange.enabled": "true"
      },
      "defaultClientScopes": [
        "customer-id",
        "transfer-service-audience"
      ],
      "protocolMappers": [
        {
          "name": "customerId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "customerId",
            "claim.name": "customerId",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "aud-transfer-service",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "transfer-service",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "transfer-service",
      "name": "Transfer Service Audience",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "bearerOnly": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Banking",
      "email": "alice@example.com",
      "attributes": {
        "customerId": [
          "CC-200"
        ]
      },
      "realmRoles": [
        "transfer_read",
        "transfer_write"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    },
    {
      "username": "bob",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Bob",
      "lastName": "Banking",
      "email": "bob@example.com",
      "attributes": {
        "customerId": [
          "CC-201"
        ]
      },
      "realmRoles": [
        "transfer_read",
        "transfer_write"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ]
}
